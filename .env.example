# Copy this file to .env and fill in your values.
# The systemd service reads these via the Environment= directive.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ---------------------------------------------------------------------------
# Claude CLI (default backend)
# ---------------------------------------------------------------------------

# Full path to the claude CLI binary.
# Find it with: which claude
CLAUDE_CLI_COMMAND=/home/youruser/.nvm/versions/node/v24.14.0/bin/claude

# ---------------------------------------------------------------------------
# Inference backend selection
# ---------------------------------------------------------------------------

# Options: claude_cli | ollama (ollama requires OLLAMA_BASE_URL and OLLAMA_MODEL)
INFERENCE_BACKEND=claude_cli

# Ollama remote inference (uncomment when ready)
# OLLAMA_BASE_URL=http://10.0.0.x:11434
# OLLAMA_MODEL=qwen2.5:7b

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------

# Seconds Claude CLI is allowed for a single chat reply
# CLAUDE_CHAT_TIMEOUT=120

# Seconds Claude CLI is allowed for a full agent run (30 minutes default)
# CLAUDE_AGENT_TIMEOUT=1800

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------

# TELEGRAM_REQUEST_TIMEOUT=30
# TELEGRAM_POLL_TIMEOUT=25
# TELEGRAM_CHUNK_SIZE=3500

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# AGENT_DB_PATH=data/agent_state.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# LOG_LEVEL=INFO
